#!/usr/bin/env bash

## Description: Install Coder post-start hook into this DDEV project
## Usage: coder-setup
## Example: "ddev coder-setup"

set -euo pipefail

if [ ! -f ".ddev/config.yaml" ]; then
  echo "Error: no .ddev/config.yaml found. Run 'ddev config' first."
  exit 1
fi

# Write config.coder.yaml alongside config.yaml
if [ -z "${VSCODE_PROXY_URI:-}" ]; then
  echo "Warning: VSCODE_PROXY_URI not set — web container will not have it available"
fi
cat > .ddev/config.coder.yaml << EOF
# Coder-specific DDEV hooks (auto-generated by ddev coder-setup, do not edit)
#
# Coder environment variables injected into the DDEV web container so that
# tools running inside it (e.g. Vite/Astro dev servers) can construct correct
# URLs and detect the Coder environment:
#   CODER                      - set to "true"; use to detect a Coder workspace
#   CODER_AGENT_URL            - Coder server base URL (e.g. ${CODER_AGENT_URL:-https://coder.example.com/})
#   CODER_WORKSPACE_AGENT_NAME - agent name used in Coder subdomain URLs (e.g. ${CODER_WORKSPACE_AGENT_NAME:-main})
#   CODER_WORKSPACE_NAME       - workspace name; used in subdomain URL construction (e.g. ${CODER_WORKSPACE_NAME:-myproject})
#   CODER_WORKSPACE_OWNER_NAME - workspace owner; used in subdomain URL construction (e.g. ${CODER_WORKSPACE_OWNER_NAME:-username})
#   VSCODE_PROXY_URI           - proxy URL template for port forwarding
#                                (e.g. ${VSCODE_PROXY_URI:-https://{{port}}--agent--workspace--owner.domain})
#                                used to derive the allowed host domain for dev servers
web_environment:
  - CODER=${CODER:-}
  - CODER_AGENT_URL=${CODER_AGENT_URL:-}
  - CODER_WORKSPACE_AGENT_NAME=${CODER_WORKSPACE_AGENT_NAME:-}
  - CODER_WORKSPACE_NAME=${CODER_WORKSPACE_NAME:-}
  - CODER_WORKSPACE_OWNER_NAME=${CODER_WORKSPACE_OWNER_NAME:-}
  - VSCODE_PROXY_URI=${VSCODE_PROXY_URI:-}
hooks:
  post-start:
    - exec-host: ~/.ddev/commands/host/coder-routes
EOF
echo "✓ Wrote .ddev/config.coder.yaml"

# Gitignore it so it doesn't end up in the project repo
mkdir -p ~/.config/git
if ! grep -qF ".ddev/config.coder.yaml" ~/.config/git/ignore 2>/dev/null; then
  echo ".ddev/config.coder.yaml" >> ~/.config/git/ignore
  echo "✓ Added .ddev/config.coder.yaml to ~/.config/git/ignore"
fi

echo ""
echo "Coder routing hook installed. Run 'ddev start' to activate routing."
echo "The hook runs automatically after every 'ddev start'."
